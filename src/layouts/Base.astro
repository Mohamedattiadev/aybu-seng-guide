---
import '../styles/global.css';
interface Props { title?: string }
const { title = 'AYBU Software Engineering — Student Guide' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="description" content="Unofficial AYBU Software Engineering student guide — curriculum, internships, graduation, faculty, ASEC club." />
  <title>{title}</title>
  <script is:inline>
    document.documentElement.setAttribute(
      'data-theme',
      localStorage.getItem('aybu-theme') || 'auto'
    );
  </script>
</head>
<body>
  <slot />
</body>
</html>
